# =============================================================================
# Helmes Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Signal Configuration ---
# Your Signal phone number with country code (e.g., +84901234567)
SIGNAL_PHONE_NUMBER=+84XXXXXXXXX

# Signal CLI REST API URL (internal Docker network, do not change)
SIGNAL_API_URL=http://signal-api:8080

# --- AI Configuration ---
# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Base URL for Anthropic API (for third-party proxies like OpenRouter, etc.)
# Leave empty to use official Anthropic API (https://api.anthropic.com)
ANTHROPIC_BASE_URL=

# Claude model to use (model name may differ on third-party providers)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Max tokens for AI response
AI_MAX_TOKENS=4096

# Default system prompt for the AI agent
AI_SYSTEM_PROMPT=You are Helmes, a highly capable AI assistant running on a Linux server, communicating via Signal. You have access to tools: bash commands, file read/write, and Python execution on the server. Use these tools proactively to help the user with coding, system administration, and automation tasks. Working directory is /workspace. Respond in the same language the user writes in.

# --- Access Control ---
# Admin phone numbers (comma-separated, with country code)
# Admins can use /system, /model, and other admin commands
ADMIN_NUMBERS=+84XXXXXXXXX

# Allowed phone numbers (* = everyone, or comma-separated numbers)
ALLOWED_NUMBERS=*

# --- Agent Settings ---
# Max messages kept in conversation history per user
MAX_CONVERSATION_LENGTH=50

# Rate limit: max messages per user per hour (0 = unlimited)
RATE_LIMIT_PER_HOUR=30

# Polling interval in seconds (how often to check for new messages)
POLL_INTERVAL=2

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Tool Use / Function Calling ---
# Enable tools (bash, file_read, file_write, python)
TOOLS_ENABLED=true

# Restrict tools to admin numbers only
TOOLS_ADMIN_ONLY=false

# Workspace directory for file operations
WORKSPACE_DIR=/workspace

# Tool execution timeout in seconds
TOOL_TIMEOUT=120

# Max tool call iterations per message
MAX_TOOL_ITERATIONS=30

# Thinking budget for thinking models (e.g., claude-opus-4-6-thinking)
THINKING_BUDGET=10000
